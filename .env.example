# ── Ports ───────────────────────────────────────────────────
# Change these if port 80/443 is already in use on your host
HTTP_PORT=80
# HTTPS_PORT=443

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_USER=portsight
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=portsight

# ── Backend ────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_generate_a_64_char_hex_string

# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_ENCRYPTION_KEY=CHANGE_ME_generate_a_fernet_key

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Comma-separated origins allowed to call the API
# Must match the URL users type in their browser (include port if non-standard)
# Examples:
#   CORS_ORIGINS=http://192.168.1.50
#   CORS_ORIGINS=https://portsight.company.com
#   CORS_ORIGINS=http://localhost:3000
CORS_ORIGINS=http://localhost

# Strip DNS domain suffix from switch sysName (e.g. sw1.corp.com → sw1)
STRIP_SWITCH_DOMAIN=false

# Scheduled poll time (24h format, server timezone)
POLL_SCHEDULE_HOUR=2
POLL_SCHEDULE_MINUTE=0
